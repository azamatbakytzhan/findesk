# Database (Supabase)
# DATABASE_URL — PgBouncer (port 6543, transaction mode). НЕ добавлять connection_limit=1
DATABASE_URL="postgresql://postgres:[password]@db.[project].supabase.co:6543/postgres?pgbouncer=true"
# DIRECT_URL — прямое соединение для миграций (port 5432)
DIRECT_URL="postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres"

# Auth
NEXTAUTH_SECRET="[generate: openssl rand -base64 32]"
NEXTAUTH_URL="https://findesk.kz"
AUTH_SECRET="[same as NEXTAUTH_SECRET]"

# Anthropic (AI Agent)
ANTHROPIC_API_KEY="sk-ant-..."

# Resend (Email digest)
RESEND_API_KEY="re_..."
FROM_EMAIL="digest@findesk.kz"

# Telegram Bot
TELEGRAM_BOT_TOKEN="..."
TELEGRAM_WEBHOOK_SECRET="[random string for webhook verification]"

# Vercel Cron
CRON_SECRET="[random string min 32 chars]"

# App
NEXT_PUBLIC_APP_URL="https://findesk.kz"
NEXT_PUBLIC_APP_NAME="Findesk"
