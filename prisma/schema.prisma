generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id          String    @id @default(cuid())
  name        String
  bin         String?
  plan        Plan      @default(START)
  trialEndsAt DateTime?
  timezone    String    @default("Asia/Almaty")
  currency    String    @default("KZT")
  createdAt   DateTime  @default(now())

  users           User[]
  accounts        Account[]
  transactions    Transaction[]
  categories      Category[]
  projects        Project[]
  counterparties  Counterparty[]
  budgets         Budget[]
  automationRules AutomationRule[]
  paymentRequests PaymentRequest[]
  aiConversations AiConversation[]
}

model User {
  id             String   @id @default(cuid())
  organizationId String
  email          String   @unique
  name           String?
  passwordHash   String?
  role           UserRole @default(VIEWER)
  avatar         String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
}

enum UserRole {
  OWNER
  ADMIN
  ACCOUNTANT
  MANAGER
  VIEWER
}

enum Plan {
  START
  BUSINESS
  FIRST
}

model Account {
  id             String      @id @default(cuid())
  organizationId String
  name           String
  type           AccountType
  currency       String      @default("KZT")
  balance        Decimal     @default(0) @db.Decimal(15, 2)
  color          String?
  isArchived     Boolean     @default(false)
  createdAt      DateTime    @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id])
  transactions Transaction[]
}

enum AccountType {
  BANK
  CASH
  CARD
  EWALLET
}

model Transaction {
  id             String          @id @default(cuid())
  organizationId String
  accountId      String
  type           TransactionType
  amount         Decimal         @db.Decimal(15, 2)
  currency       String          @default("KZT")
  date           DateTime
  categoryId     String?
  projectId      String?
  counterpartyId String?
  description    String?
  tags           String[]
  isPlanned      Boolean         @default(false)
  isConfirmed    Boolean         @default(true)
  aiSuggested    Boolean         @default(false)
  attachmentUrl  String?
  createdAt      DateTime        @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id])
  account      Account       @relation(fields: [accountId], references: [id])
  category     Category?     @relation(fields: [categoryId], references: [id])
  project      Project?      @relation(fields: [projectId], references: [id])
  counterparty Counterparty? @relation(fields: [counterpartyId], references: [id])
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

model Category {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  type           CategoryType
  parentId       String?
  color          String?
  isSystem       Boolean      @default(false)
  createdAt      DateTime     @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id])
  parent       Category?     @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children     Category[]    @relation("CategoryHierarchy")
  transactions Transaction[]
  budgets      Budget[]
}

enum CategoryType {
  INCOME
  EXPENSE
  OPERATIONAL
  INVESTMENT
  FINANCIAL
}

model Project {
  id             String        @id @default(cuid())
  organizationId String
  name           String
  status         ProjectStatus @default(ACTIVE)
  budget         Decimal?      @db.Decimal(15, 2)
  color          String?
  createdAt      DateTime      @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id])
  transactions Transaction[]
  budgets      Budget[]
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

model Counterparty {
  id             String           @id @default(cuid())
  organizationId String
  name           String
  type           CounterpartyType
  bin            String?
  phone          String?
  email          String?
  createdAt      DateTime         @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id])
  transactions Transaction[]
}

enum CounterpartyType {
  CLIENT
  SUPPLIER
  EMPLOYEE
  OTHER
}

model Budget {
  id             String  @id @default(cuid())
  organizationId String
  categoryId     String?
  projectId      String?
  period         String
  plannedAmount  Decimal @db.Decimal(15, 2)

  organization Organization @relation(fields: [organizationId], references: [id])
  category     Category?    @relation(fields: [categoryId], references: [id])
  project      Project?     @relation(fields: [projectId], references: [id])

  @@unique([organizationId, period, categoryId])
}

model AutomationRule {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  conditions     Json
  conditionLogic String   @default("AND")
  actions        Json
  priority       Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
}

model PaymentRequest {
  id             String               @id @default(cuid())
  organizationId String
  amount         Decimal              @db.Decimal(15, 2)
  currency       String               @default("KZT")
  description    String
  categoryId     String?
  projectId      String?
  status         PaymentRequestStatus @default(PENDING)
  createdById    String
  approvedById   String?
  dueDate        DateTime?
  createdAt      DateTime             @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
}

enum PaymentRequestStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model AiConversation {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  messages       Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
}
